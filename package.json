{
  "name": "sitedoc",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "db:migrate": "pnpm --filter @sitedoc/db migrate",
    "db:seed": "pnpm --filter @sitedoc/db seed",
    "db:studio": "pnpm --filter @sitedoc/db studio",
    "db:generate": "pnpm --filter @sitedoc/db generate"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "turbo": "^2.8.12"
  }
}
