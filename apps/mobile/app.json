{
  "expo": {
    "name": "SiteDoc",
    "slug": "sitedoc",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "sitedoc",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kemyrhau.sitedoc"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e40af"
      },
      "package": "com.sitedoc.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SiteDoc trenger tilgang til posisjonen din for GPS-tagging av bilder."
        }
      ],
      "expo-sqlite",
      "expo-web-browser",
      [
        "react-native-maps",
        {
          "useAppleMap": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SiteDoc trenger tilgang til bildegalleriet for vedlegg.",
          "cameraPermission": "SiteDoc trenger tilgang til kameraet for å ta bilder."
        }
      ]
    ]
  }
}
