{
  "expo": {
    "name": "SiteFlow",
    "slug": "siteflow",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "siteflow",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.siteflow.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e40af"
      },
      "package": "com.siteflow.app"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SiteFlow trenger tilgang til posisjonen din for GPS-tagging av bilder."
        }
      ],
      "expo-sqlite",
      "expo-web-browser",
      [
        "react-native-maps",
        {
          "useAppleMap": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SiteFlow trenger tilgang til bildegalleriet for vedlegg.",
          "cameraPermission": "SiteFlow trenger tilgang til kameraet for å ta bilder."
        }
      ]
    ]
  }
}
