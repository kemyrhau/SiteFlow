{
  "expo": {
    "name": "SiteDoc",
    "slug": "sitedoc",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "sitedoc",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kemyrhau.sitedoc",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e40af"
      },
      "package": "com.sitedoc.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SiteDoc trenger tilgang til posisjonen din for GPS-tagging av bilder."
        }
      ],
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "SiteDoc trenger tilgang til bildegalleriet for vedlegg.",
          "cameraPermission": "SiteDoc trenger tilgang til kameraet for å ta bilder."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a54b16c0-5d4d-402e-95b1-966bc15f20cd"
      }
    }
  }
}
