generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime? @map("email_verified")
  image           String?
  phone           String?
  role            String    @default("user") // "user" | "company_admin" | "sitedoc_admin"
  organizationId  String?   @map("organization_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization         Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  accounts             Account[]
  sessions             Session[]
  projects             ProjectMember[]
  createdChecklists    Checklist[]        @relation("ChecklistCreator")
  createdTasks         Task[]             @relation("TaskCreator")
  sentTransfers        DocumentTransfer[] @relation("TransferSender")
  drawingRevisions     DrawingRevision[]  @relation("DrawingRevisionUploader")
  sentInvitations      ProjectInvitation[] @relation("InvitationSender")
  folderAccess         FolderAccess[]
  taskComments         TaskComment[]
  checklistChangeLogs  ChecklistChangeLog[]

  @@map("users")
}

model Organization {
  id                 String   @id @default(uuid())
  name               String
  organizationNumber String?  @map("organization_number") // Org.nr (norsk)
  invoiceAddress     String?  @map("invoice_address")
  invoiceEmail       String?  @map("invoice_email")
  ehfEnabled         Boolean  @default(false) @map("ehf_enabled")
  logoUrl            String?  @map("logo_url")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  users    User[]
  projects OrganizationProject[]

  @@map("organizations")
}

model OrganizationProject {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  projectId      String   @map("project_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([organizationId, projectId])
  @@map("organization_projects")
}

// Auth.js-tabeller for OAuth-tilkoblinger
model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id            String   @id @default(uuid())
  projectNumber String   @unique @map("project_number")
  name          String
  description   String?
  address       String?
  latitude              Float?   @map("latitude")
  longitude             Float?   @map("longitude")
  internalProjectNumber String?  @map("internal_project_number")
  externalProjectNumber String?  @map("external_project_number")
  logoUrl               String?  @map("logo_url")
  showInternalProjectNumber Boolean @default(true) @map("show_internal_project_number")
  status                String   @default("active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  members              ProjectMember[]
  enterprises          Enterprise[]
  drawings             Drawing[]
  buildings            Building[]
  templates            ReportTemplate[]
  folders              Folder[]
  groups               ProjectGroup[]
  invitations          ProjectInvitation[]
  modules              ProjectModule[]
  organizationProjects OrganizationProject[]

  @@map("projects")
}

model ProjectMember {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  projectId    String   @map("project_id")
  role         String   @default("member")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enterprises MemberEnterprise[]
  groupMemberships ProjectGroupMember[]

  @@unique([userId, projectId])
  @@map("project_members")
}

model MemberEnterprise {
  id              String   @id @default(uuid())
  projectMemberId String   @map("project_member_id")
  enterpriseId    String   @map("enterprise_id")
  createdAt       DateTime @default(now()) @map("created_at")

  projectMember ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)
  enterprise    Enterprise    @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, enterpriseId])
  @@map("member_enterprises")
}

model ProjectGroup {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  slug        String
  category    String   @default("field") // generelt, field, brukergrupper
  permissions Json     @default("[]")
  domains     Json     @default("[]")  // ["bygg"], ["hms"], ["bygg","hms"], etc.
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project          Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members          ProjectGroupMember[]
  invitations      ProjectInvitation[]
  folderAccess     FolderAccess[]
  groupEnterprises GroupEnterprise[]

  @@unique([projectId, slug])
  @@map("project_groups")
}

model ProjectGroupMember {
  id              String   @id @default(uuid())
  groupId         String   @map("group_id")
  projectMemberId String   @map("project_member_id")
  createdAt       DateTime @default(now()) @map("created_at")

  group         ProjectGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  projectMember ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)

  @@unique([groupId, projectMemberId])
  @@map("project_group_members")
}

model GroupEnterprise {
  id           String   @id @default(uuid())
  groupId      String   @map("group_id")
  enterpriseId String   @map("enterprise_id")
  createdAt    DateTime @default(now()) @map("created_at")

  group      ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  enterprise Enterprise   @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@unique([groupId, enterpriseId])
  @@map("group_enterprises")
}

model ProjectInvitation {
  id              String    @id @default(uuid())
  email           String
  token           String    @unique
  projectId       String    @map("project_id")
  role            String    @default("member")
  enterpriseId    String?   @map("enterprise_id")
  groupId         String?   @map("group_id")
  invitedByUserId String    @map("invited_by_user_id")
  status          String    @default("pending") // pending | accepted | expired
  expiresAt       DateTime  @map("expires_at")
  acceptedAt      DateTime? @map("accepted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enterprise Enterprise?    @relation(fields: [enterpriseId], references: [id], onDelete: SetNull)
  group      ProjectGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  invitedBy  User           @relation("InvitationSender", fields: [invitedByUserId], references: [id])

  @@index([email])
  @@map("project_invitations")
}

model Enterprise {
  id                 String   @id @default(uuid())
  projectId          String   @map("project_id")
  name               String
  enterpriseNumber   String?  @map("enterprise_number")
  organizationNumber String?  @map("organization_number")
  color              String?
  industry           String?
  companyName        String?  @map("company_name")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  project            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memberEnterprises  MemberEnterprise[]
  createdChecklists  Checklist[]      @relation("ChecklistCreatorEnterprise")
  respondChecklists  Checklist[]      @relation("ChecklistResponderEnterprise")
  createdTasks       Task[]           @relation("TaskCreatorEnterprise")
  respondTasks       Task[]           @relation("TaskResponderEnterprise")
  createdWorkflows    Workflow[]       @relation("WorkflowCreator")
  respondWorkflows    Workflow[]       @relation("WorkflowResponder")
  respondWorkflows2   Workflow[]       @relation("WorkflowResponder2")
  respondWorkflows3   Workflow[]       @relation("WorkflowResponder3")
  invitations        ProjectInvitation[]
  folderAccess       FolderAccess[]
  groupEnterprises   GroupEnterprise[]

  @@map("enterprises")
}

model Drawing {
  id            String    @id @default(uuid())
  projectId     String    @map("project_id")
  buildingId    String?   @map("building_id")
  name          String
  drawingNumber String?   @map("drawing_number")     // Tegningsnummer: ARK-P-101
  discipline    String?                               // Fagdisiplin: ARK, RIB, RIV, RIE, RIBr, RIG, LARK, RIAku
  drawingType   String?   @map("drawing_type")        // Tegningstype: plan, snitt, fasade, detalj, oversikt, skjema
  revision      String    @default("A")               // Revisjonskode: A, B, C eller R01, R02
  version       Int       @default(1)                 // Internversjon (økes ved opplasting)
  status        String    @default("utkast")          // utkast, delt, under_behandling, godkjent, for_bygging, som_bygget
  floor         String?                               // Etasje: U2, U1, 01, 02, 03, Tak
  scale         String?                               // Målestokk: 1:50, 1:100, 1:200
  description   String?                               // Innholdsbeskrivelse
  originator    String?                               // Opphav (firma/person)
  fileUrl       String    @map("file_url")
  fileType      String    @map("file_type")           // PDF, DWG, DXF, IFC
  fileSize      Int?      @map("file_size")           // Filstørrelse i bytes
  issuedAt      DateTime? @map("issued_at")           // Utstedelsesdato
  geoReference  Json?     @map("geo_reference")       // Georeferanse med 2 referansepunkter
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  building   Building?         @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  revisions  DrawingRevision[]
  tasks      Task[]
  checklists Checklist[]

  @@map("drawings")
}

model DrawingRevision {
  id           String   @id @default(uuid())
  drawingId    String   @map("drawing_id")
  revision     String                                  // Revisjonskode ved denne versjonen (A, B, C)
  version      Int                                     // Versjonsnummer ved denne revisjonen
  fileUrl      String   @map("file_url")
  fileSize     Int?     @map("file_size")
  description  String?                                 // Beskrivelse av endringer
  uploadedById String?  @map("uploaded_by_id")
  status       String                                  // Status ved revisjon
  issuedAt     DateTime? @map("issued_at")
  createdAt    DateTime @default(now()) @map("created_at")

  drawing    Drawing @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("DrawingRevisionUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@map("drawing_revisions")
}

model Building {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  number      Int?     @map("number")
  name        String
  description String?
  address     String?
  type        String   @default("bygg")  // "bygg" | "anlegg"
  status      String   @default("unpublished")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  drawings   Drawing[]
  checklists Checklist[]

  @@map("buildings")
}

model ReportTemplate {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  prefix      String?
  category    String   @default("sjekkliste") // "oppgave" | "sjekkliste"
  domain      String   @default("bygg")      // "bygg" | "hms" | "kvalitet"
  subjects    Json?    @default("[]")         // Forhåndsdefinerte emnetekster ["3. etasje", "Kjeller", ...]
  version        Int      @default(1)
  enableChangeLog Boolean @default(false) @map("enable_change_log")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  objects            ReportObject[]
  checklists         Checklist[]
  tasks              Task[]
  workflowTemplates  WorkflowTemplate[]

  @@map("report_templates")
}

model ReportObject {
  id         String   @id @default(uuid())
  templateId String   @map("template_id")
  parentId   String?  @map("parent_id")
  type       String
  label      String
  config     Json     @default("{}")
  sortOrder  Int      @map("sort_order")
  required   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  template ReportTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent   ReportObject?   @relation("ObjektHierarki", fields: [parentId], references: [id], onDelete: Cascade)
  children ReportObject[]  @relation("ObjektHierarki")

  @@index([parentId])
  @@map("report_objects")
}

model Checklist {
  id                   String   @id @default(uuid())
  templateId           String   @map("template_id")
  creatorUserId        String   @map("creator_user_id")
  creatorEnterpriseId  String   @map("creator_enterprise_id")
  responderEnterpriseId String  @map("responder_enterprise_id")
  status               String   @default("draft")
  title                String
  number               Int?     @map("number")
  data                 Json     @default("{}")
  dueDate              DateTime? @map("due_date")
  workflowId           String?  @map("workflow_id")
  subject              String?
  buildingId           String?  @map("building_id")
  drawingId            String?  @map("drawing_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  template           ReportTemplate     @relation(fields: [templateId], references: [id])
  creator            User               @relation("ChecklistCreator", fields: [creatorUserId], references: [id])
  creatorEnterprise  Enterprise         @relation("ChecklistCreatorEnterprise", fields: [creatorEnterpriseId], references: [id])
  responderEnterprise Enterprise        @relation("ChecklistResponderEnterprise", fields: [responderEnterpriseId], references: [id])
  workflow           Workflow?          @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  building           Building?          @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  drawing            Drawing?           @relation(fields: [drawingId], references: [id], onDelete: SetNull)
  transfers          DocumentTransfer[]
  images             Image[]
  tasks              Task[]
  changeLog          ChecklistChangeLog[]

  @@map("checklists")
}

model Task {
  id                   String    @id @default(uuid())
  templateId           String?   @map("template_id")
  creatorUserId        String    @map("creator_user_id")
  creatorEnterpriseId  String    @map("creator_enterprise_id")
  responderEnterpriseId String   @map("responder_enterprise_id")
  status               String    @default("draft")
  title                String
  description          String?
  number               Int?      @map("number")
  priority             String    @default("medium")
  dueDate              DateTime? @map("due_date")
  drawingId            String?   @map("drawing_id")
  positionX            Float?    @map("position_x")
  positionY            Float?    @map("position_y")
  workflowId           String?   @map("workflow_id")
  checklistId          String?   @map("checklist_id")
  checklistFieldId     String?   @map("checklist_field_id")
  data                 Json?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  template           ReportTemplate?    @relation(fields: [templateId], references: [id])
  creator            User               @relation("TaskCreator", fields: [creatorUserId], references: [id])
  creatorEnterprise  Enterprise         @relation("TaskCreatorEnterprise", fields: [creatorEnterpriseId], references: [id])
  responderEnterprise Enterprise        @relation("TaskResponderEnterprise", fields: [responderEnterpriseId], references: [id])
  drawing            Drawing?           @relation(fields: [drawingId], references: [id])
  workflow           Workflow?          @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  checklist          Checklist?         @relation(fields: [checklistId], references: [id], onDelete: SetNull)
  transfers          DocumentTransfer[]
  images             Image[]
  comments           TaskComment[]

  @@map("tasks")
}

model DocumentTransfer {
  id           String   @id @default(uuid())
  checklistId  String?  @map("checklist_id")
  taskId       String?  @map("task_id")
  senderId     String   @map("sender_id")
  fromStatus   String   @map("from_status")
  toStatus     String   @map("to_status")
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  checklist Checklist? @relation(fields: [checklistId], references: [id])
  task      Task?      @relation(fields: [taskId], references: [id])
  sender    User       @relation("TransferSender", fields: [senderId], references: [id])

  @@map("document_transfers")
}

model Image {
  id          String   @id @default(uuid())
  checklistId String?  @map("checklist_id")
  taskId      String?  @map("task_id")
  fileUrl     String   @map("file_url")
  fileName    String   @map("file_name")
  fileSize    Int      @map("file_size")
  gpsLat      Float?   @map("gps_lat")
  gpsLng      Float?   @map("gps_lng")
  gpsEnabled  Boolean  @default(true) @map("gps_enabled")
  createdAt   DateTime @default(now()) @map("created_at")

  checklist Checklist? @relation(fields: [checklistId], references: [id])
  task      Task?      @relation(fields: [taskId], references: [id])

  @@map("images")
}

model Folder {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  parentId   String?  @map("parent_id")
  name       String
  accessMode String   @default("inherit") @map("access_mode") // "inherit" | "custom"
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        Folder?        @relation("FolderHierarchy", fields: [parentId], references: [id])
  children      Folder[]       @relation("FolderHierarchy")
  documents     Document[]
  accessEntries FolderAccess[]

  @@map("folders")
}

model FolderAccess {
  id           String   @id @default(uuid())
  folderId     String   @map("folder_id")
  accessType   String   @map("access_type") // "enterprise" | "group" | "user"
  enterpriseId String?  @map("enterprise_id")
  groupId      String?  @map("group_id")
  userId       String?  @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  folder     Folder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  enterprise Enterprise?   @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  group      ProjectGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([folderId, accessType, enterpriseId, groupId, userId])
  @@map("folder_access")
}

model Document {
  id        String   @id @default(uuid())
  folderId  String   @map("folder_id")
  name      String
  fileUrl   String   @map("file_url")
  fileType  String   @map("file_type")
  fileSize  Int      @map("file_size")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Workflow {
  id                     String   @id @default(uuid())
  enterpriseId           String   @map("enterprise_id")
  responderEnterpriseId  String?  @map("responder_enterprise_id")
  responderEnterprise2Id String?  @map("responder_enterprise_2_id")
  responderEnterprise3Id String?  @map("responder_enterprise_3_id")
  name                   String
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  enterprise           Enterprise  @relation("WorkflowCreator", fields: [enterpriseId], references: [id], onDelete: Cascade)
  responderEnterprise  Enterprise? @relation("WorkflowResponder", fields: [responderEnterpriseId], references: [id], onDelete: SetNull)
  responderEnterprise2 Enterprise? @relation("WorkflowResponder2", fields: [responderEnterprise2Id], references: [id], onDelete: SetNull)
  responderEnterprise3 Enterprise? @relation("WorkflowResponder3", fields: [responderEnterprise3Id], references: [id], onDelete: SetNull)
  templates            WorkflowTemplate[]
  checklists           Checklist[]
  tasks                Task[]

  @@map("workflows")
}

model WorkflowTemplate {
  id         String   @id @default(uuid())
  workflowId String   @map("workflow_id")
  templateId String   @map("template_id")
  createdAt  DateTime @default(now()) @map("created_at")

  workflow Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  template ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([workflowId, templateId])
  @@map("workflow_templates")
}

model ProjectModule {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  moduleSlug String   @map("module_slug")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, moduleSlug])
  @@map("project_modules")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@map("task_comments")
}

model ChecklistChangeLog {
  id          String   @id @default(uuid())
  checklistId String   @map("checklist_id")
  userId      String   @map("user_id")
  fieldId     String   @map("field_id")
  fieldLabel  String   @map("field_label")
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at")

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([checklistId])
  @@map("checklist_change_log")
}
